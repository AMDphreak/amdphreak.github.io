---
export interface Props {
  href?: string;
  text: string;
  variant?: "default" | "primary" | "secondary";
  size?: "sm" | "md" | "lg";
  onclick?: string;
}

const {
  href,
  text,
  variant = "default",
  size = "md",
  onclick,
} = Astro.props as Props;

// Size classes
const sizeClasses = {
  sm: "px-2 py-1 text-[10px]",
  md: "px-4 py-2 text-xs",
  lg: "px-6 py-3 text-sm",
};

// Variant classes
const variantClasses = {
  default: "border-stone-200 dark:border-stone-800 text-stone-600 dark:text-stone-400 hover:bg-stone-50 dark:hover:bg-stone-900",
  primary: "border-stone-900 dark:border-stone-100 text-stone-900 dark:text-stone-100 font-bold hover:bg-stone-100 dark:hover:bg-stone-800",
  secondary: "border-dashed border-stone-300 dark:border-stone-700 text-stone-500 hover:border-stone-500 transition-colors",
};
---

{
  href ? (
    <a
      href={href}
      class={`inline-flex items-center justify-center border font-mono uppercase tracking-[0.2em] transition-all duration-200 ${sizeClasses[size]} ${variantClasses[variant]}`}
    >
      {text}
    </a>
  ) : (
    <button
      class={`inline-flex items-center justify-center border font-mono uppercase tracking-[0.2em] transition-all duration-200 ${sizeClasses[size]} ${variantClasses[variant]}`}
      onclick={onclick}
    >
      {text}
    </a>
  )
}
