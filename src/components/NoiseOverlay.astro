---
import { noiseLayers } from "../lib/noise-layers";
---

<div class="noise-overlay" data-noise-overlay aria-hidden="true">
  {
    noiseLayers.map((layer) => (
      <div
        class="noise-layer"
        style={{
          "--noise-x": `${layer.x}px`,
          "--noise-y": `${layer.y}px`,
          "--noise-rot": `${layer.rot}deg`,
          "--noise-layer-opacity": layer.opacity,
        }}
      />
    ))
  }
</div>

<script is:inline define:vars={{ noiseLayers }}>
  (function () {
    const storageKey = "noise-overlay-v1";
    const root = document.querySelector("[data-noise-overlay]:not(.noise-overlay--initialized)");
    if (!(root instanceof HTMLElement)) {
      return;
    }

    let config = null;
    try {
      config = sessionStorage.getItem(storageKey);
    } catch {
      /* private browsing */
    }

    if (!config) {
      let seed = 0;
      try {
        const stored = sessionStorage.getItem("noise-overlay-seed");
        seed = stored ? Number(stored) : (Date.now() ^ (Math.random() * 0x7fffffff)) | 0;
        sessionStorage.setItem("noise-overlay-seed", String(seed));
      } catch {
        seed = (Date.now() ^ (Math.random() * 0x7fffffff)) | 0;
      }

      const rand = (function mulberry32(a) {
        return function () {
          a |= 0;
          a = (a + 0x6d2b79f5) | 0;
          let t = Math.imul(a ^ (a >>> 15), 1 | a);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      })(seed);

      const tile = 64;
      const layers = noiseLayers.map((base, index) => {
        const r = rand();
        const angle = base.rot + (r - 0.5) * 24;
        const offsetX = base.x + Math.round((rand() - 0.5) * tile * 0.9);
        const offsetY = base.y + Math.round((rand() - 0.5) * tile * 0.9);
        return {
          x: offsetX,
          y: offsetY,
          rot: Math.round(angle * 10) / 10,
          opacity: base.opacity * (0.92 + rand() * 0.16),
          index,
        };
      });

      config = JSON.stringify(layers);
      try {
        sessionStorage.setItem(storageKey, config);
      } catch {
        /* ignore */
      }
    }

    const layers = JSON.parse(config);
    const layerEls = root.querySelectorAll(".noise-layer");
    for (const layer of layers) {
      const el = layerEls[layer.index];
      if (!(el instanceof HTMLElement)) continue;
      el.style.setProperty("--noise-x", `${layer.x}px`);
      el.style.setProperty("--noise-y", `${layer.y}px`);
      el.style.setProperty("--noise-rot", `${layer.rot}deg`);
      el.style.setProperty("--noise-layer-opacity", String(layer.opacity));
    }

    root.classList.add("noise-overlay--initialized");
  })();
</script>
